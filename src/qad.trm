/* ============================================================
 * TERM_BODY
 * ============================================================ */

#ifdef TERM_BODY

typedef struct QAD_bytebuf {
    unsigned char* data;
    size_t size;
    size_t cap;
    int failed;
} QAD_bytebuf;

static QAD_bytebuf QAD_svg_buf;


typedef enum QAD_format {
    QAD_FORMAT_SVG = 0,
    QAD_FORMAT_PNG,
    QAD_FORMAT_JPG,
    QAD_FORMAT_BMP,
    QAD_FORMAT_PDF,
    QAD_FORMAT_RGBA,
    QAD_FORMAT_RGB
} QAD_format;

static QAD_format QAD_output_format = QAD_FORMAT_SVG;
static int QAD_jpg_quality = 90;
static double QAD_pdf_dpi = 300.0;
static double QAD_pdf_page_width_pt = 0.0;
static double QAD_pdf_page_height_pt = 0.0;
static unsigned QAD_pdf_render_width_px = 0;
static unsigned QAD_pdf_render_height_px = 0;

/* PDF defaults:
 *   A4 portrait = 210 mm x 297 mm.
 *   Common office margins = 1 inch on both sides.
 *   Available width = 8.2677 - 2 = 6.2677 inch.
 *   Keep gnuplot/pdfcairo's familiar 5:3 default plot aspect.
 */
#define QAD_PDF_DEFAULT_WIDTH_IN   6.2677165354
#define QAD_PDF_DEFAULT_HEIGHT_IN  (QAD_PDF_DEFAULT_WIDTH_IN * 3.0 / 5.0)
#define QAD_PDF_POINTS_PER_INCH    72.0

/* Implemented in src/helpers.cpp */
extern int qadgnuplotlib_svg_to_raw_rgba_lunasvg(
    const char* svg_text,
    unsigned width_px,
    unsigned height_px,
    unsigned char** out_rgba,
    size_t* out_rgba_size);

extern int qadgnuplotlib_svg_to_raw_rgb_lunasvg(
    const char* svg_text,
    unsigned width_px,
    unsigned height_px,
    unsigned char background_r,
    unsigned char background_g,
    unsigned char background_b,
    unsigned char** out_rgb,
    size_t* out_rgb_size);

extern int qadgnuplotlib_svg_to_png_memory_lunasvg(
    const char* svg_text,
    unsigned width_px,
    unsigned height_px,
    unsigned char background_r,
    unsigned char background_g,
    unsigned char background_b,
    unsigned char** out_data,
    size_t* out_size);

extern int qadgnuplotlib_svg_to_jpg_memory_lunasvg(
    const char* svg_text,
    unsigned width_px,
    unsigned height_px,
    unsigned char background_r,
    unsigned char background_g,
    unsigned char background_b,
    int quality,
    unsigned char** out_data,
    size_t* out_size);

extern int qadgnuplotlib_write_png_memory(
    unsigned width,
    unsigned height,
    unsigned components,
    const unsigned char* raw,
    unsigned char** out_data,
    size_t* out_size);

extern int qadgnuplotlib_write_jpg_memory(
    unsigned width,
    unsigned height,
    unsigned components,
    const unsigned char* raw,
    int quality,
    unsigned char** out_data,
    size_t* out_size);

extern int qadgnuplotlib_write_bmp_memory(
    unsigned width,
    unsigned height,
    unsigned components,
    const unsigned char* raw,
    unsigned char** out_data,
    size_t* out_size);

extern int qadgnuplotlib_make_raster_pdf_from_raw_rgb(
    unsigned image_width_px,
    unsigned image_height_px,
    double page_width_pt,
    double page_height_pt,
    const unsigned char* raw_rgb,
    size_t raw_rgb_size,
    unsigned char** out_pdf,
    size_t* out_pdf_size);


static void
QAD_buf_clear(QAD_bytebuf* b)
{
    if (!b)
        return;

    b->size = 0;
    b->failed = 0;
}


static void
QAD_buf_free(QAD_bytebuf* b)
{
    if (!b)
        return;

    free(b->data);
    b->data = NULL;
    b->size = 0;
    b->cap = 0;
    b->failed = 0;
}


static int
QAD_buf_reserve(QAD_bytebuf* b, size_t extra)
{
    size_t need;
    size_t new_cap;
    unsigned char* p;

    if (!b || b->failed)
        return 1;

    need = b->size + extra;

    if (need <= b->cap)
        return 0;

    new_cap = b->cap ? b->cap * 2 : 16384;

    while (new_cap < need) {
        size_t doubled = new_cap * 2;

        if (doubled <= new_cap) {
            b->failed = 1;
            return 1;
        }

        new_cap = doubled;
    }

    p = (unsigned char*)realloc(b->data, new_cap);

    if (!p) {
        b->failed = 1;
        return 1;
    }

    b->data = p;
    b->cap = new_cap;

    return 0;
}


static int
QAD_buf_write(QAD_bytebuf* b, const void* data, size_t len)
{
    if (!data && len != 0)
        return 1;

    if (QAD_buf_reserve(b, len))
        return 1;

    if (len != 0) {
        memcpy(b->data + b->size, data, len);
        b->size += len;
    }

    return 0;
}


static int
QAD_buf_vprintf(QAD_bytebuf* b, const char* fmt, va_list ap)
{
    va_list ap2;
    int n;

    if (!b || !fmt || b->failed)
        return -1;

    va_copy(ap2, ap);
    n = vsnprintf(NULL, 0, fmt, ap2);
    va_end(ap2);

    if (n < 0) {
        b->failed = 1;
        return -1;
    }

    if (QAD_buf_reserve(b, (size_t)n + 1))
        return -1;

    vsnprintf((char*)b->data + b->size, (size_t)n + 1, fmt, ap);
    b->size += (size_t)n;

    return n;
}


/* ============================================================
 * SVG stdio capture
 * ============================================================ */

static int
QAD_svg_fprintf(FILE* stream, const char* fmt, ...)
{
    va_list ap;
    int r;

    (void)stream;

    va_start(ap, fmt);
    r = QAD_buf_vprintf(&QAD_svg_buf, fmt, ap);
    va_end(ap);

    return r;
}


static int
QAD_svg_fputs(const char* s, FILE* stream)
{
    (void)stream;

    if (!s)
        return EOF;

    return QAD_buf_write(&QAD_svg_buf, s, strlen(s)) ? EOF : 0;
}


static int
QAD_svg_fputc(int c, FILE* stream)
{
    unsigned char ch = (unsigned char)c;

    (void)stream;

    return QAD_buf_write(&QAD_svg_buf, &ch, 1) ? EOF : c;
}


static int
QAD_svg_fflush(FILE* stream)
{
    (void)stream;
    return 0;
}


/* ============================================================
 * Include svg.trm exactly once
 * ============================================================ */

#pragma push_macro("fprintf")
#pragma push_macro("fputs")
#pragma push_macro("fputc")
#pragma push_macro("fflush")

#ifdef fprintf
#undef fprintf
#endif
#ifdef fputs
#undef fputs
#endif
#ifdef fputc
#undef fputc
#endif
#ifdef fflush
#undef fflush
#endif

#define fprintf QAD_svg_fprintf
#define fputs   QAD_svg_fputs
#define fputc   QAD_svg_fputc
#define fflush  QAD_svg_fflush

#include "../gnuplot-main/term/svg.trm"

#undef fprintf
#undef fputs
#undef fputc
#undef fflush

#pragma pop_macro("fflush")
#pragma pop_macro("fputc")
#pragma pop_macro("fputs")
#pragma pop_macro("fprintf")


 /* ============================================================
  * QAD finalizer
  * First version: write captured SVG as-is.
  * ============================================================ */

static int
QAD_write_bytes_to_gpoutfile(const unsigned char* data, size_t size)
{
    if (!data || size == 0 || !gpoutfile)
        return 1;

    if (fwrite(data, 1, size, gpoutfile) != size)
        return 1;

    fflush(gpoutfile);
    return 0;
}


static char*
QAD_svg_make_c_string(const unsigned char* svg, size_t svg_size)
{
    char* s;

    if (!svg || svg_size == 0)
        return NULL;

    s = (char*)malloc(svg_size + 1);
    if (!s)
        return NULL;

    memcpy(s, svg, svg_size);
    s[svg_size] = '\0';
    return s;
}


static unsigned
QAD_pixel_width(void)
{
    return (unsigned)((QAD_SVG_xSize + (unsigned)(SVG_SCALE / 2)) / (unsigned)SVG_SCALE);
}


static unsigned
QAD_pixel_height(void)
{
    return (unsigned)((QAD_SVG_ySize + (unsigned)(SVG_SCALE / 2)) / (unsigned)SVG_SCALE);
}


static unsigned
QAD_round_to_uint(double v)
{
    if (v <= 0.0)
        return 0;
    return (unsigned)(v + 0.5);
}


static void
QAD_set_pdf_physical_size_pt(double width_pt, double height_pt)
{
    QAD_pdf_page_width_pt = width_pt;
    QAD_pdf_page_height_pt = height_pt;

    QAD_pdf_render_width_px = QAD_round_to_uint((width_pt * QAD_pdf_dpi) / QAD_PDF_POINTS_PER_INCH);
    QAD_pdf_render_height_px = QAD_round_to_uint((height_pt * QAD_pdf_dpi) / QAD_PDF_POINTS_PER_INCH);
}


static void
QAD_apply_default_pdf_size_if_needed(void)
{
    if (QAD_output_format != QAD_FORMAT_PDF)
        return;

    if (QAD_pdf_page_width_pt <= 0.0 || QAD_pdf_page_height_pt <= 0.0) {
        QAD_set_pdf_physical_size_pt(
            QAD_PDF_DEFAULT_WIDTH_IN * QAD_PDF_POINTS_PER_INCH,
            QAD_PDF_DEFAULT_HEIGHT_IN * QAD_PDF_POINTS_PER_INCH);
    } else {
        /* dpi may have appeared after size in the command line. */
        QAD_set_pdf_physical_size_pt(
            QAD_pdf_page_width_pt,
            QAD_pdf_page_height_pt);
    }
}


static int
QAD_finalize_output(const unsigned char* svg, size_t svg_size)
{
    char* svg_text = NULL;
    unsigned width;
    unsigned height;
    unsigned char* raw = NULL;
    size_t raw_size = 0;
    unsigned char* encoded = NULL;
    size_t encoded_size = 0;
    int err = 1;

    if (!svg || svg_size == 0 || !gpoutfile)
        return 1;

    if (QAD_output_format == QAD_FORMAT_SVG)
        return QAD_write_bytes_to_gpoutfile(svg, svg_size);

    svg_text = QAD_svg_make_c_string(svg, svg_size);
    if (!svg_text)
        goto done;

    width = QAD_pixel_width();
    height = QAD_pixel_height();

    if (width == 0 || height == 0)
        goto done;

    switch (QAD_output_format) {
    case QAD_FORMAT_PNG:
        /* Use an opaque white background by default.
         * If we write RGBA, most viewers show the transparent plot background
         * as black, making black axes/text disappear. Raw alpha is still
         * available through format rgba.
         */
        if (qadgnuplotlib_svg_to_png_memory_lunasvg(svg_text, width, height, 255, 255, 255, &encoded, &encoded_size))
            goto done;
        err = QAD_write_bytes_to_gpoutfile(encoded, encoded_size);
        break;

    case QAD_FORMAT_JPG:
        if (qadgnuplotlib_svg_to_jpg_memory_lunasvg(svg_text, width, height, 255, 255, 255, QAD_jpg_quality, &encoded, &encoded_size))
            goto done;
        err = QAD_write_bytes_to_gpoutfile(encoded, encoded_size);
        break;

    case QAD_FORMAT_BMP:
        if (qadgnuplotlib_svg_to_raw_rgb_lunasvg(svg_text, width, height, 255, 255, 255, &raw, &raw_size))
            goto done;
        if (qadgnuplotlib_write_bmp_memory(width, height, 3, raw, &encoded, &encoded_size))
            goto done;
        err = QAD_write_bytes_to_gpoutfile(encoded, encoded_size);
        break;

    case QAD_FORMAT_PDF:
        if (qadgnuplotlib_svg_to_raw_rgb_lunasvg(svg_text, width, height, 255, 255, 255, &raw, &raw_size))
            goto done;
        {
            double page_w = QAD_pdf_page_width_pt;
            double page_h = QAD_pdf_page_height_pt;

            if (page_w <= 0.0 || page_h <= 0.0) {
                page_w = ((double)width * 72.0) / QAD_pdf_dpi;
                page_h = ((double)height * 72.0) / QAD_pdf_dpi;
            }

            if (qadgnuplotlib_make_raster_pdf_from_raw_rgb(
                width,
                height,
                page_w,
                page_h,
                raw,
                raw_size,
                &encoded,
                &encoded_size))
                goto done;
        }
        err = QAD_write_bytes_to_gpoutfile(encoded, encoded_size);
        break;

    case QAD_FORMAT_RGBA:
        if (qadgnuplotlib_svg_to_raw_rgba_lunasvg(svg_text, width, height, &raw, &raw_size))
            goto done;
        err = QAD_write_bytes_to_gpoutfile(raw, raw_size);
        break;

    case QAD_FORMAT_RGB:
        if (qadgnuplotlib_svg_to_raw_rgb_lunasvg(svg_text, width, height, 255, 255, 255, &raw, &raw_size))
            goto done;
        err = QAD_write_bytes_to_gpoutfile(raw, raw_size);
        break;

    case QAD_FORMAT_SVG:
    default:
        err = 1;
        break;
    }

done:
    free(svg_text);
    free(raw);
    free(encoded);
    return err;
}


static void
QAD_remove_tokens(int first, int count)
{
    int tail;

    if (count <= 0 || first < 0 || first >= num_tokens)
        return;

    if (first + count > num_tokens)
        count = num_tokens - first;

    tail = num_tokens - (first + count) + 1; /* include sentinel token */
    if (tail > 0)
        memmove(&token[first], &token[first + count], (size_t)tail * sizeof(token[0]));

    num_tokens -= count;
}


static void
QAD_parse_private_options(void)
{
    int i = c_token;

    QAD_output_format = QAD_FORMAT_SVG;
    QAD_jpg_quality = 90;
    QAD_pdf_dpi = 300.0;
    QAD_pdf_page_width_pt = 0.0;
    QAD_pdf_page_height_pt = 0.0;
    QAD_pdf_render_width_px = 0;
    QAD_pdf_render_height_px = 0;

    /* First pass only discovers the output format.
     * This lets "set term qad size 10cm,6cm format pdf" work even
     * though size appears before format.
     */
    while (i < num_tokens) {
        if (equals(i, "format") && i + 1 < num_tokens) {
            if (equals(i + 1, "pdf"))
                QAD_output_format = QAD_FORMAT_PDF;
            else if (equals(i + 1, "svg"))
                QAD_output_format = QAD_FORMAT_SVG;
            else if (equals(i + 1, "png"))
                QAD_output_format = QAD_FORMAT_PNG;
            else if (equals(i + 1, "jpg") || equals(i + 1, "jpeg"))
                QAD_output_format = QAD_FORMAT_JPG;
            else if (equals(i + 1, "bmp"))
                QAD_output_format = QAD_FORMAT_BMP;
            else if (equals(i + 1, "rgba"))
                QAD_output_format = QAD_FORMAT_RGBA;
            else if (equals(i + 1, "rgb"))
                QAD_output_format = QAD_FORMAT_RGB;
        }
        i++;
    }

    i = c_token;

    while (i < num_tokens) {
        if (equals(i, "format")) {
            if (i + 1 >= num_tokens)
                int_error(i, "qad: expecting output format");

            if (equals(i + 1, "svg"))
                QAD_output_format = QAD_FORMAT_SVG;
            else if (equals(i + 1, "png"))
                QAD_output_format = QAD_FORMAT_PNG;
            else if (equals(i + 1, "jpg") || equals(i + 1, "jpeg"))
                QAD_output_format = QAD_FORMAT_JPG;
            else if (equals(i + 1, "bmp"))
                QAD_output_format = QAD_FORMAT_BMP;
            else if (equals(i + 1, "pdf"))
                QAD_output_format = QAD_FORMAT_PDF;
            else if (equals(i + 1, "rgba"))
                QAD_output_format = QAD_FORMAT_RGBA;
            else if (equals(i + 1, "rgb"))
                QAD_output_format = QAD_FORMAT_RGB;
            else
                int_error(i + 1, "qad: unknown output format");

            QAD_remove_tokens(i, 2);
            continue;
        }

        if (almost_equals(i, "s$ize") && QAD_output_format == QAD_FORMAT_PDF) {
            int saved = c_token;
            float w = 0.0f;
            float h = 0.0f;

            c_token = i + 1;

            /* For PDF, "size" is physical size, just like pdfcairo.
             * No suffix means inches.  "cm" and "inches" are accepted.
             * parse_term_size() returns dimensions in gp_resolution units;
             * in practice gp_resolution is 72, i.e. PDF points.
             */
            parse_term_size(&w, &h, INCHES);

            QAD_set_pdf_physical_size_pt((double)w, (double)h);

            QAD_remove_tokens(i, c_token - i);
            c_token = saved;
            continue;
        }

        if (equals(i, "quality")) {
            int saved = c_token;
            c_token = i + 1;
            QAD_jpg_quality = (int)real_expression();
            if (QAD_jpg_quality < 1)
                QAD_jpg_quality = 1;
            if (QAD_jpg_quality > 100)
                QAD_jpg_quality = 100;
            QAD_remove_tokens(i, c_token - i);
            c_token = saved;
            continue;
        }

        if (equals(i, "dpi")) {
            int saved = c_token;
            c_token = i + 1;
            QAD_pdf_dpi = real_expression();
            if (QAD_pdf_dpi < 1.0)
                QAD_pdf_dpi = 300.0;
            QAD_remove_tokens(i, c_token - i);
            c_token = saved;
            continue;
        }

        if (equals(i, "pdfsize")) {
            int saved = c_token;
            float w = 0.0f;
            float h = 0.0f;

            c_token = i + 1;

            /* Kept as a compatibility alias for the previous patch. */
            parse_term_size(&w, &h, INCHES);

            QAD_set_pdf_physical_size_pt((double)w, (double)h);

            QAD_remove_tokens(i, c_token - i);
            c_token = saved;
            continue;
        }

        i++;
    }
}


/* ============================================================
 * QAD public callbacks
 * ============================================================ */

TERM_PUBLIC void
QAD_options(void)
{
    QAD_parse_private_options();
    QAD_apply_default_pdf_size_if_needed();

    QAD_SVG_options();

    if (QAD_output_format == QAD_FORMAT_PDF
    && QAD_pdf_render_width_px > 0
    && QAD_pdf_render_height_px > 0) {
        QAD_SVG_xSize = QAD_pdf_render_width_px * SVG_SCALE;
        QAD_SVG_ySize = QAD_pdf_render_height_px * SVG_SCALE;
        QAD_SVG_fixed_size = TRUE;
    }

    term->xmax = QAD_SVG_xSize;
    term->ymax = QAD_SVG_ySize;

    switch (QAD_output_format) {
    case QAD_FORMAT_SVG:
        sprintf(term_options, "qad size %u,%u format svg", QAD_pixel_width(), QAD_pixel_height());
        break;
    case QAD_FORMAT_PNG:
        sprintf(term_options, "qad size %u,%u format png", QAD_pixel_width(), QAD_pixel_height());
        break;
    case QAD_FORMAT_JPG:
        sprintf(term_options, "qad size %u,%u format jpg quality %d", QAD_pixel_width(), QAD_pixel_height(), QAD_jpg_quality);
        break;
    case QAD_FORMAT_BMP:
        sprintf(term_options, "qad size %u,%u format bmp", QAD_pixel_width(), QAD_pixel_height());
        break;
    case QAD_FORMAT_PDF:
        sprintf(term_options, "qad size %.4gin,%.4gin format pdf dpi %.0f",
            QAD_pdf_page_width_pt / QAD_PDF_POINTS_PER_INCH,
            QAD_pdf_page_height_pt / QAD_PDF_POINTS_PER_INCH,
            QAD_pdf_dpi);
        break;
    case QAD_FORMAT_RGBA:
        sprintf(term_options, "qad size %u,%u format rgba", QAD_pixel_width(), QAD_pixel_height());
        break;
    case QAD_FORMAT_RGB:
        sprintf(term_options, "qad size %u,%u format rgb", QAD_pixel_width(), QAD_pixel_height());
        break;
    default:
        sprintf(term_options, "qad via svg");
        break;
    }
}


TERM_PUBLIC void
QAD_init(void)
{
    QAD_buf_clear(&QAD_svg_buf);
    QAD_SVG_init();
}


TERM_PUBLIC void
QAD_graphics(void)
{
    QAD_buf_clear(&QAD_svg_buf);
    QAD_SVG_graphics();
}


TERM_PUBLIC void
QAD_text(void)
{
    QAD_SVG_text();

    if (QAD_svg_buf.failed) {
        os_error(NO_CARET, "qad: failed while capturing SVG output");
        return;
    }

    if (QAD_finalize_output(QAD_svg_buf.data, QAD_svg_buf.size)) {
        os_error(NO_CARET, "qad: failed while finalizing output");
        return;
    }
}


TERM_PUBLIC void
QAD_reset(void)
{
    QAD_SVG_reset();
    QAD_buf_free(&QAD_svg_buf);
}

#endif /* TERM_BODY */


