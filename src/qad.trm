#ifdef TERM_HELP
    START_HELP(qad)
    "1 qad",
    "?commands set terminal qad",
    "?set terminal qad",
    "?set term qad",
    "?terminal qad",
    "?term qad",
    "?qad",
    " The `qad` terminal is an embedded backend that wraps the SVG terminal",
    " and captures SVG output in memory.",
    "",
    " Examples:",
    "     set terminal qad size 800,600 format png",
    "     set terminal qad size 10cm,6cm format pdf dpi 300",
    "     set terminal qad format pdf",
    "",
    " For SVG/PNG/JPG/BMP/raw formats, `size` is pixels.",
    " For PDF, `size` is physical page size.  No unit means inches,",
    " like pdfcairo.  The `dpi` option converts this physical size to",
    " the internal raster size.  Default PDF size is A4 portrait width",
    " minus common 1 inch margins, preserving a 5:3 plot aspect ratio."
    END_HELP(qad)
#endif

